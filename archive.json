  "issues": [
    {
      "number": 2,
      "id": "I_kwDORSN2L87x6sQo",
      "title": "Countersignature is not needed",
      "url": "https://github.com/tireddy2/draft-reddy-rats-key-binding/issues/2",
      "state": "CLOSED",
      "author": "tireddy2",
      "authorAssociation": "OWNER",
      "assignees": [],
      "labels": [],
      "body": "If the EAT carries the Subject Public Key in the cnf claim, and the verifier checks that this key matches the key used in the CSR or TLS authentication, then the AK-signed EAT provides evidence about the platform protecting the corresponding private key, while the CSR or TLS signature proves control of that private key. I therefore do not see a need for an additional countersignature.\n\nIn the previous version, the TEE generated the PoP to provide direct evidence of possession of the Subject Key.",
      "createdAt": "2026-03-11T14:48:47Z",
      "updatedAt": "2026-03-15T07:13:56Z",
      "closedAt": "2026-03-15T07:13:56Z",
      "comments": []
    }
  ],
  "pulls": [
